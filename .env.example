# LLM Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest
OLLAMA_REFINEMENT_MODEL=gemma4:latest

# Image Generation API (Pexels or Unsplash)
# Note: The code uses PEXELS_API_KEY in stage_visuals.py but UNSPLASH in app.py/env. 
# Ensure your keys match your implementation.
UNSPLASH_ACCESS_KEY=your_access_key_here
UNSPLASH_SECRET_KEY=your_secret_key_here

# Pexels (if using Pexels)
PEXELS_API_KEY=your_pexels_key_here
